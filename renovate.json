{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "enabledManagers": ["github-actions", "custom.regex"],
  "ignoreDeps": ["imagemagick"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^libraries\\.json$/"
      ],
      "matchStrings": ["\"key\":\\s*\"libjpeg_turbo\"[\\s\\S]*?\"version\":\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "libjpeg-turbo/libjpeg-turbo",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^libraries\\.json$/"
      ],
      "matchStrings": ["\"key\":\\s*\"libpng\"[\\s\\S]*?\"version\":\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "glennrp/libpng",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "loose",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^libraries\\.json$/"
      ],
      "matchStrings": ["\"key\":\\s*\"libtiff\"[\\s\\S]*?\"version\":\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "libtiff/libtiff",
      "datasourceTemplate": "gitlab-releases",
      "registryUrlTemplate": "https://gitlab.com",
      "versioningTemplate": "loose",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^libraries\\.json$/"
      ],
      "matchStrings": ["\"key\":\\s*\"lcms2\"[\\s\\S]*?\"version\":\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "mm2/Little-CMS",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "loose",
      "extractVersionTemplate": "^lcms(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^libraries\\.json$/"
      ],
      "matchStrings": ["\"key\":\\s*\"libwebp\"[\\s\\S]*?\"version\":\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "webmproject/libwebp",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "loose",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^libraries\\.json$/"
      ],
      "matchStrings": ["\"key\":\\s*\"libaom\"[\\s\\S]*?\"version\":\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "https://aomedia.googlesource.com/aom",
      "datasourceTemplate": "git-tags",
      "versioningTemplate": "loose",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^libraries\\.json$/"
      ],
      "matchStrings": ["\"key\":\\s*\"libde265\"[\\s\\S]*?\"version\":\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "strukturag/libde265",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "loose",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^libraries\\.json$/"
      ],
      "matchStrings": ["\"key\":\\s*\"libheif\"[\\s\\S]*?\"version\":\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "strukturag/libheif",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "loose",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    }
  ],
  "packageRules": [
    {
      "description": "Ubuntu versions in test-installer.yml are intentional test matrix entries (test targets), not dependency updates",
      "matchFileNames": [".github/workflows/test-installer.yml"],
      "matchDepPatterns": ["^ubuntu"],
      "enabled": false
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions"
    },
    {
      "matchManagers": ["custom.regex"],
      "groupName": "bundled libraries"
    }
  ]
}
